# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to git

# ---------------------------------------------------------------------------
# Soulseek credentials (create a free account at soulseekqt.net)
# ---------------------------------------------------------------------------
SLSK_USERNAME=your_soulseek_username
SLSK_PASSWORD=your_soulseek_password

# slskd API key — generate with: openssl rand -base64 32
SLSKD_API_KEY=your_api_key_here

# slskd web UI port (default 5030, accessible at http://localhost:5030)
SLSKD_PORT=5030

# ---------------------------------------------------------------------------
# Folder paths
# ---------------------------------------------------------------------------

# Local staging folder where downloads land before being moved to final destination
DOWNLOAD_DIR=/Users/YOURUSERNAME/Music/SoulseekStage

# Music folder to share with the Soulseek network (read-only)
SHARE_DIR=/Users/YOURUSERNAME/Library/Mobile Documents/com~apple~CloudDocs/Music

# Destination folder where synced tracks are delivered
DEST_DIR=/Users/YOURUSERNAME/Music/SoulSync

# ---------------------------------------------------------------------------
# API keys for source adapters and title parsing
# ---------------------------------------------------------------------------

# Anthropic API key for Claude Haiku title parsing (https://console.anthropic.com)
# Named SOULSEEK_SYNC_ANTHROPIC_KEY (not ANTHROPIC_API_KEY) to avoid dev tools
# picking it up from the shell environment.
SOULSEEK_SYNC_ANTHROPIC_KEY=your_anthropic_api_key_here

# Spotify (optional — needed only if you add a Spotify source)
#
# Setup steps:
#   1. Create a free app at https://developer.spotify.com/dashboard
#   2. Copy the Client ID and Client Secret into the fields below
#   3. In the app settings, add this Redirect URI:
#        http://127.0.0.1:8888/callback
#   4. Under "User Management", add your Spotify account email
#   5. Run the one-time auth:
#        docker compose exec -it automator python -m sources.spotify_auth
#      This opens a URL — paste it in your browser, log in, click Agree,
#      then copy the redirect URL back into the terminal.
#   6. Done! The token auto-refreshes — you won't need to do this again.
#
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Discogs (optional — needed only if you add a Discogs source)
# Create a personal access token at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# ---------------------------------------------------------------------------
# Legacy fallback (optional — sources are now managed in the dashboard)
# ---------------------------------------------------------------------------

# YouTube playlist URL — only used if no sources are configured in the dashboard
YOUTUBE_PLAYLIST_URL=
